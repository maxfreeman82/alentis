# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App URL (utilisé pour les redirections auth) ───────────────────────────────
NEXT_PUBLIC_APP_URL=https://votre-domaine.com

# ── Anthropic (analytics IA) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (emails transactionnels) ──────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@votre-domaine.com

# ── PayDunya (paiements Afrique) ─────────────────────────────────────────────
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test

# ── Sécurité ─────────────────────────────────────────────────────────────────
# Clé secrète pour les sessions iron-session (32+ caractères aléatoires)
SESSION_SECRET=changez-moi-par-une-chaine-aleatoire-longue-et-complexe
